{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "collector/Dockerfile.metrics",
    "watchPatterns": [
      "collector/**"
    ]
  },
  "deploy": {
    "startCommand": "python collect.py",
    "cronSchedule": "30 22 * * 1-5",
    "restartPolicyType": "NEVER"
  }
}
