# Tastytrade credentials
TT_LOGIN=your@email.com
TT_PASSWORD=yourpassword

# Auto-renewed by the script; populate after first manual login
TT_REMEMBER_TOKEN=

# Railway PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/dbname

# Alert email (when remember-token expires and needs manual renewal)
ALERT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=yourapppassword
