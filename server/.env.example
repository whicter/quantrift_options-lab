DATABASE_URL=postgres://user:password@host:5432/dbname
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:4173

# Snapshot freshness / cache policy
IV_STALE_DAYS=2
OPTIONS_STALE_MINUTES=180
SCANNER_STALE_MINUTES=5
METRICS_CACHE_SECONDS=60
GEX_CACHE_SECONDS=120
CHAIN_CACHE_SECONDS=120
SCANNER_CACHE_SECONDS=60
UNUSUAL_CACHE_SECONDS=60
UNUSUAL_STALE_MINUTES=1440
USE_DERIVED_VOLATILITY=true
SCANNER_QUOTE_STALE_MINUTES=1440

# Refresh queue policy
SCAN_KEY=watchlist_v1
REFRESH_MIN_INTERVAL_SECONDS=60
OPTIONS_REFRESH_PROVIDER=polygon_licensed
PROVIDER_DAILY_BUDGET=1000

# Public half of the VAPID key pair used by browser subscriptions.
WEB_PUSH_VAPID_PUBLIC_KEY=

# Collector liveness heartbeat. Set the same token on Mac Studio and Railway.
HEARTBEAT_TOKEN=
HEARTBEAT_EXPECTED_NODES=mac-studio
HEARTBEAT_MAX_AGE_SECONDS=180
HEARTBEAT_MONITOR_SECONDS=60
HEARTBEAT_ALERT_COOLDOWN_SECONDS=3600
HEARTBEAT_MONITOR_ENABLED=true
ALERT_WEBHOOK_URL=

# Clerk authentication. Keep enforcement off until both frontend and backend keys are deployed.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=https://www.quantrift.io,http://localhost:5173
AUTH_ENFORCEMENT_ENABLED=false

# Stripe billing. Plan changes are accepted only from signed webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
PUBLIC_APP_URL=https://www.quantrift.io
