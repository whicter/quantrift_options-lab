DATABASE_URL=postgres://user:password@host:5432/dbname
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:4173

# Snapshot freshness / cache policy
IV_STALE_DAYS=2
OPTIONS_STALE_MINUTES=180
SCANNER_STALE_MINUTES=5
METRICS_CACHE_SECONDS=60
GEX_CACHE_SECONDS=120
CHAIN_CACHE_SECONDS=120
SCANNER_CACHE_SECONDS=60
UNUSUAL_CACHE_SECONDS=60
UNUSUAL_STALE_MINUTES=1440
USE_DERIVED_VOLATILITY=true

# Refresh queue policy
SCAN_KEY=watchlist_v1
REFRESH_MIN_INTERVAL_SECONDS=60
OPTIONS_REFRESH_PROVIDER=polygon_licensed
PROVIDER_DAILY_BUDGET=1000
