# Tastytrade credentials
TT_LOGIN=your@email.com
TT_PASSWORD=yourpassword
TT_SESSION_TOKEN=
TT_BASE_URL=https://api.tastyworks.com
TT_USER_AGENT=quantrift-options-lab/0.1
# Set only while tastytrade has temporarily blocked this machine's public IP.
TT_CIRCUIT_OPEN=false
TT_TIMEOUT=20
TT_COLLECT_DXLINK=true
TT_DXLINK_TIMEOUT=12

# Auto-renewed by the script; populate after first manual login
TT_REMEMBER_TOKEN=

# Railway PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/dbname

# Price history collector
# polygon is the scheduled adapter; ib_internal remains an explicit fallback.
# stooq is only for explicit dev/backfill, not production options data.
PRICE_PROVIDER=polygon
PRICE_HISTORY_LIMIT=400
PRICE_30M_LOOKBACK_DAYS=35
POLYGON_STOCK_REQUEST_DELAY=16
POLYGON_STOCK_RATE_LIMIT_FILE=/tmp/quantrift_polygon_stock_rate_limit
POLYGON_PRICE_RATE_LIMIT_BACKOFF=60
DERIVED_VOLATILITY_ENABLED=true
DERIVED_VOLATILITY_SECONDS=3600
VOLATILITY_BACKFILL=false
IV_RANK_MIN_OBSERVATIONS=252
HV_ANNUALIZATION_DAYS=252
IB_HOST=127.0.0.1
IB_PORT=4001
IB_PRICE_CLIENT_ID=12
IB_TIMEOUT=30
IB_MARKET_DATA_TYPE=3

# Option chain collector. polygon_licensed is the production data source.
OPTION_PROVIDER=polygon_licensed
OPTION_SYMBOLS=AAPL,SPY,QQQ,PLTR
OPTION_MIN_DTE=7
OPTION_MAX_DTE=60
OPTION_STRIKE_WINDOW_PCT=15
OPTION_MAX_STRIKES_PER_SIDE=20
OPTION_MAX_CONTRACTS=500

# Polygon.io licensed options data (Options Starter, $29/month)
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_PAGE_LIMIT=250
POLYGON_REQUEST_DELAY=0.12
POLYGON_TIMEOUT=30

# IB fallback settings (kept for ib_internal if ever needed)
IB_OPTION_CLIENT_ID=42
IB_OPTION_CONTRACT_DELAY=0.05
IB_OPTION_SNAPSHOT_GRACE_SECONDS=2
IB_OPTION_STREAM_TIMEOUT=5

OPTION_AUTO_REFRESH=false
OPTION_REFRESH_PROVIDER=polygon_licensed
OPTION_REFRESH_BATCH_SIZE=2
OPTION_REFRESH_MAX_AGE_MINUTES=60
OPTION_REFRESH_RETRY_COOLDOWN_MINUTES=30
OPTION_REFRESH_SCHEDULE_SECONDS=300

# Optional per-symbol spot override used by tt_internal before DXLink quotes are merged.
# Without it, tt_internal selects strikes around the median available strike.
TT_SPOT_AAPL=
TT_SPOT_PLTR=

# GEX compute job
GEX_SYMBOLS=
OPTION_CONTRACT_MULTIPLIER=100
GEX_LOCAL_GAMMA_WINDOW_PCT=1
GEX_GAMMA_FLIP_GRID_PCT=10
GEX_GAMMA_FLIP_GRID_STEPS=81
GEX_MAX_MISSING_RATIO=0.25
GEX_RISK_FREE_RATE=0.045

# Scanner materializer
SCAN_KEY=watchlist_v1
OPTIONS_STALE_MINUTES=15

# OI delta / unusual activity materializer
OI_DELTA_SYMBOLS=
OI_DELTA_MIN_ABS=100
OI_DELTA_MIN_PCT=0.25
OI_DELTA_MIN_VOLUME=10
OI_DELTA_MAX_PREVIOUS_AGE_HOURS=96

# Refresh worker / provider budget
REFRESH_WORKER_BATCH_SIZE=10
REFRESH_WORKER_MAX_ATTEMPTS=3
PROVIDER_DAILY_BUDGET=1000
COLLECTOR_POLL_SECONDS=60
SCAN_MATERIALIZE_SECONDS=300

# Optional comma-separated override for testing/backfill.
# If omitted, collector/watchlist.txt is used.
SYMBOLS=

# Alert email (when remember-token expires and needs manual renewal)
ALERT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=yourapppassword

# Scanner email / browser-push delivery
PUBLIC_APP_URL=https://www.quantrift.io
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:alerts@quantrift.io

# Mac Studio -> Railway liveness heartbeat
HEARTBEAT_URL=https://your-railway-api.example/api/heartbeat
HEARTBEAT_TOKEN=
HEARTBEAT_NODE_ID=mac-studio
HEARTBEAT_TIMEOUT_SECONDS=10
